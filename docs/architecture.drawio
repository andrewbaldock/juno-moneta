<mxfile host="app.diagrams.net" type="device">
  <diagram name="Juno Architecture" id="juno-architecture">
    <mxGraphModel dx="1320" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1320" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Juno — System Architecture" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="React SPA · Supabase (Postgres + RLS + Edge Functions) · Claude · Vercel. The browser talks directly to Supabase under RLS; the only server code is the two edge functions." style="text;html=1;fontSize=12;align=left;fontColor=#6b7280;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="900" height="20" as="geometry" />
        </mxCell>

        <!-- Boundaries -->
        <mxCell id="clientBoundary" value="HOUSEHOLD MEMBER · BROWSER (PWA-installable)" style="rounded=1;dashed=1;dashPattern=7 5;strokeColor=#C9BDA0;fillColor=none;verticalAlign=top;align=left;fontColor=#8A7A55;fontStyle=1;fontSize=11;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="176" width="430" height="470" as="geometry" />
        </mxCell>
        <mxCell id="supaBoundary" value="SUPABASE PROJECT (juno) · region us-east-2" style="rounded=1;dashed=1;dashPattern=7 5;strokeColor=#3ECF8E;fillColor=none;verticalAlign=top;align=left;fontColor=#0B7A4F;fontStyle=1;fontSize=11;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="620" y="176" width="436" height="560" as="geometry" />
        </mxCell>

        <!-- CI / deploy band -->
        <mxCell id="github" value="GitHub · juno-moneta&#10;source of truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6b7280;" vertex="1" parent="1">
          <mxGeometry x="60" y="88" width="210" height="52" as="geometry" />
        </mxCell>
        <mxCell id="vercel" value="Vercel&#10;static SPA host + CI/CD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#111827;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="360" y="88" width="220" height="52" as="geometry" />
        </mxCell>
        <mxCell id="supaCli" value="Supabase CLI&#10;manual edge-fn deploy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#3ECF8E;fontColor=#0B7A4F;" vertex="1" parent="1">
          <mxGeometry x="1070" y="88" width="200" height="52" as="geometry" />
        </mxCell>

        <!-- Client nodes -->
        <mxCell id="spa" value="React 19 SPA — shell · screens · Recharts&#10;History-API routing (no router lib), no store&#10;Dashboard · Accounts · Cash flows · Estate · Tasks · Advisor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6b7280;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="64" y="214" width="382" height="80" as="geometry" />
        </mxCell>
        <mxCell id="engine" value="Local finance engine&#10;pure src/lib/&#10;metrics · projections&#10;amortization · runway&#10;integer cents" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6b7280;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="64" y="316" width="184" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ls" value="localStorage&#10;UI prefs &amp; task dismissals only&#10;no financial data · no secrets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6b7280;fontSize=11;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="262" y="316" width="184" height="120" as="geometry" />
        </mxCell>
        <mxCell id="clientNote" value="Claude returns scenario deltas → the local engine computes every projection; validated edits are written back to Postgres under RLS." style="text;html=1;fontSize=10;align=center;fontColor=#8A7A55;" vertex="1" parent="1">
          <mxGeometry x="60" y="458" width="390" height="34" as="geometry" />
        </mxCell>

        <!-- Supabase nodes -->
        <mxCell id="auth" value="Auth (GoTrue)&#10;email/password · JWT · reset &amp; recovery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#3ECF8E;fontColor=#0B7A4F;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="644" y="212" width="388" height="56" as="geometry" />
        </mxCell>
        <mxCell id="postgres" value="Postgres + Row-Level Security&#10;households · household_members · accounts&#10;balance_snapshots (append-only) · cash_flows&#10;conversations · messages · juno_notes · estate_items&#10;money = bigint cents · NULL = unknown&#10;is_member() SECURITY DEFINER gates every table&#10;triggers: snapshot_balance · touch_updated_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#3ECF8E;fontColor=#245C44;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="644" y="288" width="388" height="176" as="geometry" />
        </mxCell>
        <mxCell id="claudeProxy" value="Edge Function · claude-proxy (Deno)&#10;JWT-gated · holds ANTHROPIC_API_KEY&#10;system prompt + forced 'advise' tool&#10;input caps: ≤40 msgs, ≤30 KB snapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3eefb;strokeColor=#8b5cf6;fontColor=#5b21b6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="644" y="486" width="388" height="98" as="geometry" />
        </mxCell>
        <mxCell id="calIcs" value="Edge Function · calendar-ics (Deno)&#10;token-in-URL · service role key&#10;verify_jwt OFF (calendar apps fetch anonymously)&#10;emits RFC-5545 bill feed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3eefb;strokeColor=#8b5cf6;fontColor=#5b21b6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="644" y="604" width="388" height="98" as="geometry" />
        </mxCell>

        <!-- External -->
        <mxCell id="anthropic" value="Anthropic API&#10;Claude Sonnet 5 (advice)&#10;Haiku 4.5 (health)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7ede7;strokeColor=#d97757;fontColor=#a8442a;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1120" y="486" width="180" height="98" as="geometry" />
        </mxCell>
        <mxCell id="calClients" value="Google / Apple Calendar&#10;(subscribers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#6b7fd9;fontColor=#3a4aa0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1120" y="604" width="180" height="98" as="geometry" />
        </mxCell>

        <!-- Edges: runtime (solid) -->
        <mxCell id="e_gh_vercel" value="push → deploy" style="endArrow=block;html=1;dashed=1;dashPattern=5 4;strokeColor=#9ca3af;fontColor=#9ca3af;fontSize=10;" edge="1" parent="1" source="github" target="vercel">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_vercel_spa" value="serves SPA bundle" style="endArrow=block;html=1;strokeColor=#4b5563;fontSize=10;fontColor=#4b5563;" edge="1" parent="1" source="vercel" target="spa">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_spa_auth" value="sign in → JWT" style="endArrow=block;html=1;strokeColor=#4b5563;fontSize=10;fontColor=#4b5563;" edge="1" parent="1" source="spa" target="auth">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_spa_pg" value="CRUD via PostgREST (anon key + JWT, under RLS)" style="endArrow=block;html=1;strokeColor=#4b5563;strokeWidth=1.8;fontSize=10;fontColor=#4b5563;" edge="1" parent="1" source="spa" target="postgres">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_spa_proxy" value="invoke (JWT): snapshot + question" style="endArrow=block;html=1;strokeColor=#4b5563;fontSize=10;fontColor=#4b5563;" edge="1" parent="1" source="spa" target="claudeProxy">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_proxy_anthropic" value="request: names/$/rates only → advice (deltas)" style="endArrow=block;startArrow=block;html=1;strokeColor=#4b5563;fontSize=10;fontColor=#4b5563;" edge="1" parent="1" source="claudeProxy" target="anthropic">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_cal_clients" value="GET ?t=token" style="endArrow=block;html=1;strokeColor=#4b5563;fontSize=10;fontColor=#3a4aa0;" edge="1" parent="1" source="calClients" target="calIcs">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_cal_pg" value="read active cash_flows (service role)" style="endArrow=block;html=1;strokeColor=#4b5563;fontSize=10;fontColor=#4b5563;" edge="1" parent="1" source="calIcs" target="postgres">
          <mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_cli_fns" value="deploy edge fns" style="endArrow=block;html=1;dashed=1;dashPattern=5 4;strokeColor=#9ca3af;fontColor=#9ca3af;fontSize=10;" edge="1" parent="1" source="supaCli" target="claudeProxy">
          <mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Legend&#10;──▶ runtime request (HTTPS)     ┄┄▶ deploy / CI&#10;• Claude never sees raw balances, account numbers, or the jsonb detail bag.&#10;• Anon key is safe to ship — RLS, not the key, is the access boundary." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#e5ddc8;align=left;verticalAlign=top;fontSize=11;spacingLeft=8;spacingTop=6;fontColor=#4b5563;" vertex="1" parent="1">
          <mxGeometry x="40" y="676" width="430" height="118" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
